function loadLandSounds()
    for _, snd in ipairs(landSounds) do
        pcall(function() snd:Destroy() end)
    end
    landSounds = {}

    for _, id in ipairs(LAND_SOUNDS) do
        snd = Instance.new("Sound")
        snd.SoundId = id
        snd.Volume  = 1
        snd.Parent  = rootPart
        table.insert(landSounds, snd)
    end

    
    task.spawn(function()
        ContentProvider:PreloadAsync(landSounds)
    end)
end
