    if fallTrack then pcall(function() fallTrack:Stop() end) end

    anim = Instance.new("Animation")
    anim.AnimationId = FLY_ANIM_ID
    flyTrack = animator:LoadAnimation(anim)
    flyTrack.Priority = Enum.AnimationPriority.Action4
    flyTrack.Looped   = true

    diveAnim = Instance.new("Animation")
    diveAnim.AnimationId = DIVE_ANIM_ID
    diveTrack = animator:LoadAnimation(diveAnim)
    diveTrack.Priority = Enum.AnimationPriority.Action4
    diveTrack.Looped   = true

    landAnim = Instance.new("Animation")
    landAnim.AnimationId = LAND_ANIM_ID
    landTrack = animator:LoadAnimation(landAnim)
    landTrack.Priority = Enum.AnimationPriority.Action4
    landTrack.Looped   = false

    idleAnim = Instance.new("Animation")
    idleAnim.AnimationId = IDLE_ANIM_ID
    idleTrack = animator:LoadAnimation(idleAnim)
    idleTrack.Priority = Enum.AnimationPriority.Action4
    idleTrack.Looped   = true

