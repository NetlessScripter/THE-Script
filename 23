function getOrCreate(name, class)
    existing = rootPart:FindFirstChild(name)
    if existing then return existing end
    inst = Instance.new(class)
    inst.Name   = name
    inst.Parent = rootPart
    return inst
end

function initPhysics()
    bv = getOrCreate(BV_NAME, "BodyVelocity")
    bv.Velocity = Vector3.zero
    bv.MaxForce = Vector3.zero
    bv.P        = 1e4
end

function playFlySound()
    
    if fadeTween then fadeTween:Cancel(); fadeTween = nil end
    if flySound  then flySound:Destroy();  flySound  = nil end

    snd = Instance.new("Sound")
    snd.SoundId = "rbxassetid://17862829666"
    snd.Volume  = 1
    snd.Parent  = rootPart
    snd:Play()
    flySound = snd
end

function stopFlySound()
    if not flySound then return end
    snd = flySound
    if fadeTween then fadeTween:Cancel() end
    fadeTween = TweenService:Create(snd, TweenInfo.new(0.8, Enum.EasingStyle.Linear), { Volume = 0 })
    fadeTween:Play()
    fadeTween.Completed:Connect(function()
        snd:Destroy()
        if flySound  == snd  then flySound  = nil end
        if fadeTween ~= nil  then fadeTween = nil end
    end)
end

function startFlying()
    if flying then return end
    flying = true
    lastFOVTarget = nil

    FOV_NORMAL = camera.FieldOfView
    FOV_FLYING = FOV_NORMAL * 1.2

    initPhysics()
    humanoid.PlatformStand = true
    tweenFOV(FOV_NORMAL)
    wasMoving = false
    startFlyY = rootPart.Position.Y

    
    rootPart.AssemblyLinearVelocity = Vector3.new(
        rootPart.AssemblyLinearVelocity.X,
        math.max(rootPart.AssemblyLinearVelocity.Y, 18),
        rootPart.AssemblyLinearVelocity.Z
    )

    renderConn = RunService.RenderStepped:Connect(function(dt)
        bv = rootPart:FindFirstChild(BV_NAME)
        if not bv then
            initPhysics()
            bv = rootPart:FindFirstChild(BV_NAME)
            if not bv then return end
        end

        bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)

        
        dir      = controlModule:GetMoveVector()
        moving   = dir.Magnitude > 0.01
        isDiving   = moving and camera.CFrame.LookVector.Y < -0.2 and dir.Z < 0
        isBackward = dir.Z > 0
        speed    = (isDiving and 175 or FLY_SPEED)
                         * (UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) and BOOST_MULT or 1)

        
        if moving and not wasMoving then
            playFlySound()
        elseif not moving and wasMoving then
            stopFlySound()
        end
        wasMoving = moving

        
        if moving then
            vel = Vector3.zero
            if dir.X ~= 0 then vel = vel + camera.CFrame.RightVector * (dir.X * speed) end
            if dir.Z ~= 0 then vel = vel - camera.CFrame.LookVector  * (dir.Z * speed) end
            bv.Velocity = vel
        else
            bv.Velocity = Vector3.zero
        end

        if not landHitbox or not landHitbox.Parent then
            landHitbox = Instance.new("Part")
            landHitbox.Name         = "Hitbox"
            landHitbox.Size         = Vector3.new(10, 10, 10)
            landHitbox.Anchored     = true
            landHitbox.CanCollide   = false
            landHitbox.CanQuery     = false
            landHitbox.CastShadow   = false
            landHitbox.Transparency = 1
            landHitbox.CFrame       = rootPart.CFrame
            landHitbox.Parent       = workspace

            landHitbox.Touched:Connect(function(hit)
                if not flying then return end
                if hit:IsDescendantOf(character) then return end
                local hitModel = hit:FindFirstAncestorOfClass("Model")
                if hitModel == character then return end
                if landHitbox then landHitbox:Destroy(); landHitbox = nil end
                stopFlying()
                playLandAnim()
            end)
        else
            landHitbox.CFrame = rootPart.CFrame
        end

        
        if rootPart.Position.Y >= startFlyY + MAX_FLY_HEIGHT then
            stopFlying()
            falling = true
            if fallTrack and not fallTrack.IsPlaying then fallTrack:Play(0.2) end
            return
        end

        
        if moving and isDiving then
            if flyTrack.IsPlaying  then flyTrack:Stop(0.3)  end
            if idleTrack.IsPlaying then idleTrack:Stop(0.3) end
            if not diveTrack.IsPlaying then diveTrack:Play(0.3) end
        elseif moving and not isBackward then
            if diveTrack.IsPlaying then diveTrack:Stop(0.3) end
            if idleTrack.IsPlaying then idleTrack:Stop(0.3) end
            if not flyTrack.IsPlaying then flyTrack:Play(0.3) end
        else
            if flyTrack.IsPlaying  then flyTrack:Stop(0.3)  end
            if diveTrack.IsPlaying then diveTrack:Stop(0.3) end
            if not idleTrack.IsPlaying then idleTrack:Play(0.3) end
        end

        
        tweenFOV(moving and FOV_FLYING or FOV_NORMAL)

        
        look     = camera.CFrame.LookVector
        flatLook = Vector3.new(look.X, 0, look.Z)

        if moving and flatLook.Magnitude > 0.001 then
            yaw = math.atan2(-flatLook.Z, flatLook.X) - math.rad(90)

            yawDelta = yaw - prevYaw
            if yawDelta >  math.pi then yawDelta -= math.pi * 2 end
            if yawDelta < -math.pi then yawDelta += math.pi * 2 end
            bankTarget = math.clamp(-yawDelta * (BANK_ANGLE / 0.04), -BANK_ANGLE, BANK_ANGLE)
            currentBank = currentBank + (bankTarget - currentBank) * math.clamp(dt * 6, 0, 1)
            prevYaw = yaw

            rootPart.CFrame = CFrame.new(rootPart.Position)
                * CFrame.Angles(0, yaw, 0)
                * CFrame.Angles(0, 0, math.rad(currentBank))
        else
            currentBank = currentBank + (0 - currentBank) * math.clamp(dt * 7, 0, 1)
            _, yaw, _ = rootPart.CFrame:ToEulerAnglesYXZ()
            rootPart.CFrame = CFrame.new(rootPart.Position)
                * CFrame.Angles(0, yaw, 0)
                * CFrame.Angles(0, 0, math.rad(currentBank))
            prevYaw = yaw
        end
    end)
end

stopFlying = function()
    if not flying then return end
    flying = false

    if renderConn then renderConn:Disconnect(); renderConn = nil end
    if landHitbox then landHitbox:Destroy(); landHitbox = nil end

    humanoid.PlatformStand = false
    tweenFOV(FOV_NORMAL)
    lastFOVTarget = nil

    bv = rootPart:FindFirstChild(BV_NAME)
    if bv then bv.MaxForce = Vector3.zero; bv.Velocity = Vector3.zero end

    if flyTrack  and flyTrack.IsPlaying  then flyTrack:Stop(0.4)  end
    if diveTrack and diveTrack.IsPlaying then diveTrack:Stop(0.4) end
    if idleTrack and idleTrack.IsPlaying then idleTrack:Stop(0.4) end

    stopFlySound()
    currentBank = 0
end

playLandAnim = function()
    if not landTrack then return end

    if fallTrack and fallTrack.IsPlaying then fallTrack:Stop(0.2) end
    falling = false

    landTrack:Play(0.1)

    for _, snd in ipairs(landSounds) do
        snd:Play()
    end
end

