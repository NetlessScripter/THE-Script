local function EmitVFX(vfxTemplate, emitCount, keepEnabled)
    local part = vfxTemplate:Clone()
    part.Parent = rootPart
    for _, v in ipairs(part:GetChildren()) do
        if v:IsA("ParticleEmitter") then
            v:Emit(emitCount or 15)
            v.Enabled = keepEnabled or false
        end
    end
end

