-- ============================================================
-- v102: random number helper
-- ============================================================
local function randomNum(lo, hi, isInt, rng)
    local r = rng or RNG
    if not hi and lo then hi = lo; lo = 1 end
    if not hi and not lo then lo = 0; hi = 1 end
    if isInt then
        return r:NextInteger(lo, hi)
    else
        return r:NextNumber(lo, hi)
    end
end

-- ============================================================
-- v313: sound factory stub
-- (replace with your real v313 if you want crater impact sounds)
-- ============================================================
local function soundFactory(props)
    local s = Instance.new("Sound")
    if props then
        for k, v in pairs(props) do
            if k ~= "CFrame" and k ~= "Parent" then
                pcall(function() s[k] = v end)
            end
        end
        if props.CFrame then
            local a = Instance.new("Attachment")
            a.CFrame = props.CFrame
            a.Parent = workspace.Terrain
            s.Parent = a
            Debris:AddItem(a, 5)
        elseif props.Parent then
            s.Parent = props.Parent
        else
            s.Parent = workspace
        end
    end
    return s
end

-- ============================================================
-- v327: CFrame rotation helper (from-to with fallback axis)
-- ============================================================
local function cfFromTo(a, b, fallback)
    local dot   = a:Dot(b)
    local cross = a:Cross(b)
    if dot < -0.99999 then
        return CFrame.fromAxisAngle(fallback, math.pi)
    else
        return CFrame.new(0, 0, 0, cross.x, cross.y, cross.z, 1 + dot)
    end
end

-- ============================================================
-- v338: get touching parts (fires a dummy Touched to wake physics)
-- ============================================================
local function getTouching(part)
    if not part then return end
    if part.ClassName == "Model" then return end
    local conn = part.Touched:Connect(function() end)
    local touching = part:GetTouchingParts()
    conn:Disconnect()
    local result = {}
    for _, p in pairs(touching) do
        if p.Name ~= "InvisibleBorder" and p.Name ~= "InfBall" then
            table.insert(result, p)
        end
    end
    return result
end

-- ============================================================
-- v362: fling-then-fade a debris part
-- ============================================================
local function flingAndFade(part)
    TweenService:Create(part, TweenInfo.new(
        RNG:NextNumber(0.7, 1), Enum.EasingStyle.Quad, Enum.EasingDirection.Out
    ), { Size = Vector3.new() }):Play()

    part.Anchored   = false
    part.CanCollide = false
    part.CanTouch   = false

    local bv = part:FindFirstChildOfClass("BodyVelocity")
    if bv then Debris:AddItem(bv, 0) end

    local newBV = Instance.new("BodyVelocity")
    newBV.MaxForce = Vector3.new(400000, 400000, 400000)
    newBV.Velocity = Vector3.new(
        RNG:NextNumber(-10, 10),
        RNG:NextNumber(10, 17.5) * 2,
        randomNum(-10, 10)
    ) * 1.5
    newBV.Parent = part
    Debris:AddItem(newBV, 0.15)
end

-- ============================================================
-- v301: part recycler
-- ============================================================
local function recyclePart()
    if tick() - sweepTimer > 300 then
        sweepTimer = tick()
        for _, p in pairs(workspace.Thrown:GetChildren()) do
            if p:IsA("Part")
                and p:GetAttribute("Spawn")
                and not table.find(partPool, p)
                and not p:GetAttribute("DeletionImmunity")
                and tick() - p:GetAttribute("Spawn") > 60
            then
                p:Destroy()
            end
        end
        return
    end

    -- trim pool over 100
    if #partPool > 100 then
        for _ = 101, #partPool do
            local old = rawget(partPool, 101)
            table.remove(partPool, 101)
            if old then old:Destroy() end
        end
    end

    local p = rawget(partPool, 1)
    if p and not p.Parent then
        table.remove(partPool, 1)
        p = nil
    end
    if p and p.Parent then
        table.remove(partPool, 1)
        if p.Name == "starterdeb" then p.Name = "aa" end
        p.CollisionGroup = "Default"
        p:SetAttribute("Spawn", tick())
        return p
    end
end

-- ============================================================
-- v717: raycast helper  (also wired to shared.ray)
-- ============================================================
local function rayHelper(opts)
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = opts.Whitelist or opts.Ignore or rayExclude
    params.FilterType = opts.Whitelist
        and Enum.RaycastFilterType.Include
        or  Enum.RaycastFilterType.Exclude

    if opts.Blockcast then
        local r = workspace:Blockcast(opts.orig, opts.Blockcast, opts.dir, params)
        if r then return r.Instance, r.Position, r.Material, r.Normal end
    else
        local r = workspace:Raycast(opts.orig, opts.dir, params)
        if r then return r.Instance, r.Position, r.Material, r.Normal end
    end
end
shared.ray = rayHelper

-- ============================================================
-- shared.resizeparticle
-- ============================================================
shared.resizeparticle = function(emitter, mult, prop)
    local key = prop or "Size"
    if key == "Speed" then
        emitter.Speed = NumberRange.new(emitter.Speed.Min * mult, emitter.Speed.Max * mult)
        return
    end
    local kps = {}
    for _, kp in pairs(emitter[key].Keypoints) do
        table.insert(kps, NumberSequenceKeypoint.new(kp.Time, kp.Value * mult, kp.Envelope))
    end
    emitter[key] = NumberSequence.new(kps)
end

-- ============================================================
-- v471: GROUND CRATER  (main function — exported as groundCrater)
-- ============================================================
--[[
    Parameters table (v363):
      .cframe       CFrame   — impact origin
      .ground       BasePart — surface that was hit
      .normal       Vector3  — surface normal
      .Seed         number   — optional RNG seed for determinism
      .sizemult     number   — overall scale multiplier (default 1)
      .amount       number   — number of ring slab pieces (default 16)
      .add          table    — flags: .less, .keep, .sounds
      .nodebris     bool     — skip flying debris chunks
      .notiles      bool     — skip stadium tile break
      .nosound      bool     — skip crater impact SFX
      .dispersefast number   — auto-hide slabs after N seconds
      .customtween  TweenInfo
      .new          {minR, maxR} — custom ring radius range
      .Double       number   — spawn a second offset ring
      .angle / .anglecfr     — optional angle-gate for slab visibility
      .dontcollide  Player   — if LocalPlayer, set CollisionGroup nocol
]]
local function groundCrater(v363)
    if not v363.add then v363.add = {} end

    local sizeMult = v363.sizemult or 1
    local addFlags = v363.add

    -- off-screen fast-disperse early-out
    if v363.dispersefast and not shared.OnScreen(v363.cframe.Position) then
        return
    end

    local rng = Random.new(v363.Seed or tick())
    local function rnd(lo, hi) return randomNum(lo, hi, nil, rng) end

    if v363.amount then
        v363.amount = math.floor(v363.amount)
    end

    local lessDiv = addFlags.less and 2.5 or 1
    local stadiumBreakResult = nil

    -- stadium tile break
    if v363.ground.Name == "Stadium"
        and not v363.ground:GetAttribute("FakeStadium")
        and not v363.notiles
    then
        -- stub: wire to your v12 / effect dispatcher if needed
        -- stadiumBreakResult = effectDispatcher({ Effect = "Break Model", Stadium = v363.ground })
    end

    -- ---- Flying loose debris chunks ----
    local numLarge = rng:NextNumber(3, 5)
    if LocalPlayer:GetAttribute("S_FastMode") then numLarge = numLarge / 2 end
    if v363.nodebris then numLarge = 0 end

    -- water / terrain → use sand stand-in
    local isTerrain = false
    local isWaterOrTerrain = false
    if v363.ground.Material == Enum.Material.Water or v363.ground == workspace.Terrain then
        local sandProxy = {
            Material       = Enum.Material.Sand,
            Color          = Color3.fromRGB(227, 206, 157),
            Transparency   = 0,
            Anchored       = false,
            GetAttribute   = function(_) end,
        }
        v363.ground    = sandProxy
        isTerrain      = true
        isWaterOrTerrain = true
    end

    -- large tumbling chunks
    for _ = 1, numLarge do
        if not addFlags.less and not isWaterOrTerrain then
            local sz  = rng:NextNumber(1, 3)
            local p   = recyclePart() or Instance.new("Part")
            p.CollisionGroup = "nocol"
            p.CFrame  = v363.cframe * CFrame.Angles(
                math.rad(rnd(-360, 360)),
                math.rad(rnd(-360, 360)),
                math.rad(rnd(-360, 360))
            )
            p.Size        = Vector3.new(sz, sz, sz)
            p.Color       = v363.ground.Color
            p.CanCollide  = true
            p.Anchored    = false
            p.Material    = v363.ground.Material
            p.Transparency= v363.ground.Transparency
            p.Parent      = workspace.Thrown
            if p.Material == Enum.Material.Neon then
                p.Material = Enum.Material.Concrete
            end

            local bv = Instance.new("BodyVelocity")
            bv.MaxForce = Vector3.new(2e9, 2e9, 2e9)
            bv.Velocity = Vector3.new(rnd(-25, 25), rnd(5, 25), rnd(-25, 25)) * 2
            bv.Parent   = p
            Debris:AddItem(bv, 0.15)

            local fadeDelay = isWaterOrTerrain and 0 or (3 + rng:NextNumber(0, 1))
            delay(fadeDelay, function()
                TweenService:Create(p, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                    Transparency = 1,
                    Size = isWaterOrTerrain and Vector3.new() or p.Size / 1.5
                }):Play()
                delay(0.3, function()
                    p.Anchored    = true
                    p.AssemblyLinearVelocity  = Vector3.new()
                    p.AssemblyAngularVelocity = Vector3.new()
                    p.Velocity    = Vector3.new()
                    p.CanCollide  = false
                    p.CFrame      = CFrame.new(1e8, 1e8, 1e8)
                    table.insert(partPool, p)
                end)
            end)
        else
            break
        end
    end

    -- small debris pebbles
    local numSmall = rng:NextNumber(4, 7) / lessDiv
    if LocalPlayer:GetAttribute("S_FastMode") then numSmall = numSmall / 2 end
    if v363.nodebris then numSmall = 0 end

    for _ = 1, numSmall do
        if not isWaterOrTerrain then
            local sz = rng:NextNumber(0.6, 0.8)
            local p  = recyclePart() or Instance.new("Part")
            p.CFrame      = v363.cframe
            local rot     = cfFromTo(p.CFrame.UpVector, v363.normal, Vector3.new(0,1,0))
            p.CFrame      = p.CFrame * (rot * CFrame.Angles(math.pi / 2, 0, 0))
            p.CollisionGroup = "nocol"
            p.Size        = Vector3.new(sz, sz, sz)
            p.Color       = v363.ground.Color
            p.CanCollide  = true
            p.Name        = "SmallDebris"
            p.Anchored    = false
            p.Material    = v363.ground.Material
            p.Transparency= v363.ground.Transparency
            p.Parent      = workspace.Thrown
            if p.Material == Enum.Material.Neon then
                p.Material = Enum.Material.Concrete
            end

            local bv = Instance.new("BodyVelocity")
            bv.MaxForce = Vector3.new(2e9, 2e9, 2e9)
            bv.Velocity = Vector3.new(rnd(-25, 25), rnd(5, 25), rnd(-25, 25)) * 2
            bv.Parent   = p
            Debris:AddItem(bv, 0.15)

            local bav = Instance.new("BodyAngularVelocity")
            bav.Parent = p
            Debris:AddItem(bav, 0.5)

            local fd = isWaterOrTerrain and 0 or (3 + rng:NextNumber(0, 1))
            delay(fd, function()
                TweenService:Create(p, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                    Transparency = 1,
                    Size = isWaterOrTerrain and Vector3.new() or p.Size / 1.5
                }):Play()
                delay(0.3, function()
                    bav:Destroy()
                    p.Anchored    = true
                    p.AssemblyLinearVelocity  = Vector3.new()
                    p.AssemblyAngularVelocity = Vector3.new()
                    p.Velocity    = Vector3.new()
                    p.CanCollide  = false
                    p.CFrame      = CFrame.new(1e8, 1e8, 1e8)
                    table.insert(partPool, p)
                end)
            end)
        else
            break
        end
    end

    -- ---- Ring of upthrust slabs ----
    local ringSlabs = {}
    local rMin = 5
    local rMax = 7
    if v363.new then rMin = v363.new[1]; rMax = v363.new[2] end
    local avgR = (rMin + rMax) / 2

    local numSlabs = v363.amount or 16
    if LocalPlayer:GetAttribute("S_FastMode") then numSlabs = numSlabs / 2 end

    -- base ring CFrame aligned to surface normal
    local ringCF = CFrame.new(v363.cframe.p)
    ringCF = ringCF * cfFromTo(ringCF.UpVector, v363.normal, Vector3.new(0,1,0))
    ringCF = ringCF * CFrame.Angles(0, math.rad(rnd(-360, 360)), 0)

    local ringCF2 = ringCF * CFrame.Angles(0, math.rad(rnd(-16, 16)), 0)
    local isFirstSlab = true

    if rMin ~= 5 and rMax ~= 7 then
        v363.Double = 2
    end

    -- sound asset lists (used when addFlags.sounds is true)
    local SND_CRACK  = { "rbxassetid://3848076724", "rbxassetid://3848078820" }
    local SND_RUMBLE = {
        "rbxassetid://4307208601","rbxassetid://4307207425","rbxassetid://4307207693",
        "rbxassetid://4307205188","rbxassetid://3778609188","rbxassetid://3778608737",
        "rbxassetid://3744401196","rbxassetid://4307204962"
    }
    local SND_IMPACT = { "rbxassetid://4307204696", "rbxassetid://4307204452" }

    for slabIdx = 1, numSlabs do
        for ring = 1, v363.Double or 1 do
            local baseCF = (ring == 1) and ringCF or ringCF2
            if ring > 1 then avgR = avgR + 1 end

            local angle = (360 / numSlabs + 360 / numSlabs * slabIdx) / 57.29577951308232
            local sinA, cosA = math.sin(angle), math.cos(angle)
            local spawnCF = baseCF * CFrame.new(avgR * sinA, 0, avgR * cosA)

            -- small random jitter
            local jitter = rnd(-0.2, 0.2)
            spawnCF = spawnCF + spawnCF.lookVector * jitter

            local slab = recyclePart() or Instance.new("Part")
            if v363.dontcollide == LocalPlayer then
                slab.CollisionGroup = "nocol"
            end
            slab.Anchored   = true
            slab.CanCollide = false
            slab.CanTouch   = true
            slab.Material   = v363.ground.Material
            slab.Color      = v363.ground.Color

            -- orient slab facing ring
            slab.CFrame = spawnCF * CFrame.fromEulerAnglesXYZ(0, angle, 0)
            local origCF = slab.CFrame

            -- random tilt
            slab.CFrame = origCF * CFrame.Angles(math.rad(-rnd(6, 42)), 0, 0)

            -- size
            local slabW = rnd(2, 5) * (ring > 1 and 1.8 or v363.Double and 1.35 or 1)
            local slabH = rnd(1.9, 2.4)
            local slabD = rnd(2, 6)
            slab.Size = Vector3.new(slabW, slabH, slabD) * sizeMult

            -- drop slightly underground before tweening up
            slab.CFrame = slab.CFrame * CFrame.new(0, -(slab.Size.Y/3 + slab.Size.Z/3)/3, 0)
            slab.Transparency = 1
            slab.Parent = workspace.Thrown

            -- store original for later ref
            local preTiltCF = origCF

            -- check for overlapping parts to match color
            local touching    = getTouching(slab) or {}
            local matchPart   = nil
            local onGround    = nil
            local isStadium   = nil
            for _, tp in pairs(touching) do
                if not tp:IsDescendantOf(workspace.Live)
                    and tp.Name ~= "invis"
                    and tp.Parent ~= workspace.Thrown
                then
                    if tp.Material ~= v363.ground.Material then matchPart = tp end
                    table.insert(touching, tp)
                end
                if tp == v363.ground then onGround = v363.ground end
                if tp.Name == "Stadium" then isStadium = true end
            end

            -- apply small random position noise
            local noiseCF = CFrame.new(0, -3, -1.5) * CFrame.Angles(
                math.rad(rnd(-11, 11)),
                math.rad(rnd(-11, 11)),
                math.rad(rnd(-11, 11))
            )
            slab.CFrame = slab.CFrame * noiseCF
            slab.Transparency = 0
            table.insert(ringSlabs, slab)

            -- visibility / color logic
            local blocked = true
            if #touching ~= 0 then
                blocked = v363.ground:GetAttribute("Breakable") or not v363.ground.Anchored
            end

            local angleGated = false
            if v363.angle then
                local slabPos = preTiltCF.Position
                local angleBaseCF = v363.anglecfr
                local toSlab = (Vector3.new(slabPos.X, angleBaseCF.p.Y, slabPos.Z) - angleBaseCF.p).Unit
                angleGated = math.deg(math.acos(angleBaseCF.LookVector:Dot(toSlab))) <= v363.angle
            end

            if blocked or angleGated then
                if not isTerrain then
                    slab.Transparency = 1
                end
            else
                -- try to match surface colour
                if matchPart
                    and (not onGround or onGround.Name ~= "Stadium")
                    and (not isStadium or v363.ground.Name ~= "Stadium")
                then
                    if v363.ground.Material == Enum.Material.Grass and onGround then
                        local dirtPart = workspace:FindFirstChild("Preload") and workspace.Preload:FindFirstChild("Dirt")
                        if dirtPart then matchPart = dirtPart end
                    end
                    slab.Color    = matchPart.Color
                    slab.Material = matchPart.Material
                end
                slab.Transparency = v363.ground.Transparency
            end

            if slab.Transparency >= 1 then
                slab.CanCollide = false
                slab.CanTouch   = false
                slab.CanQuery   = false
            else
                slab.CanCollide = true
            end

            -- zero out any residual velocity
            if slab.Velocity.Magnitude > 0 then
                slab.AssemblyLinearVelocity  = Vector3.new()
                slab.AssemblyAngularVelocity = Vector3.new()
                slab.Velocity = Vector3.new()
            end

            -- water/terrain: immediately fling
            if isWaterOrTerrain or isTerrain then
                slab.CFrame = preTiltCF
                flingAndFade(slab)
            end

            -- one-time sound + disperse setup per ring
            if isFirstSlab then
                isFirstSlab = false

                -- dispersefast + water → adaptive wait & impact SFX
                if isWaterOrTerrain then
                    local stCount = 1
                    if stadiumBreakResult then stCount = 2 end
                    local radius  = (rMin + rMax) / 12
                    local waitT   = 0.015 + (radius < 0.8 and (0.8 - radius) * 0.02 or 0)
                    task.delay(waitT, function()
                        local canPlay = true
                        for i, rd in pairs(shared.recentdebris) do
                            if tick() - rd[2] > 0.5 then
                                shared.recentdebris[i] = nil
                            elseif (rd[1].Position - rd[1].Position).Magnitude <= 5 then
                                canPlay = false; break
                            end
                        end
                        if canPlay then
                            if radius >= 0.8 then
                                table.insert(shared.recentdebris, { baseCF, tick() })
                                soundFactory({
                                    SoundId = ({
                                        "rbxassetid://18922680029","rbxassetid://18922679331",
                                        "rbxassetid://18922678743","rbxassetid://18922678349"
                                    })[math.random(1,4)],
                                    Volume = 1.35 / stCount,
                                    CFrame  = baseCF
                                }):Play()
                            end
                        end
                    end)

                elseif addFlags.sounds and not v363.nosound then
                    -- per-slab SFX when add.sounds flag is set
                    local stCount = stadiumBreakResult and 2 or 1
                    local s1 = soundFactory({})
                    s1.SoundId = SND_IMPACT[RNG:NextInteger(1, #SND_IMPACT)]
                    s1.Volume  = 3.85 / stCount
                    s1.Parent  = slab
                    s1:Play()

                    local s2 = soundFactory({})
                    s2.SoundId = SND_RUMBLE[RNG:NextInteger(1, #SND_RUMBLE)]
                    s2.Volume  = 4.3 / stCount
                    s2.Parent  = slab
                    s2:Play()

                    local s3 = soundFactory({})
                    s3.SoundId = SND_CRACK[RNG:NextInteger(1, #SND_CRACK)]
                    s3.Volume  = 4.12 / stCount
                    s3.Parent  = slab
                    s3:Play()
                end
            end

            slab:SetAttribute("OGCframe", preTiltCF)

            -- tween slab into place
            if not isWaterOrTerrain then
                TweenService:Create(slab, TweenInfo.new(
                    rng:NextNumber(0.2, 0.3), Enum.EasingStyle.Quad, Enum.EasingDirection.Out
                ), { CFrame = preTiltCF }):Play()
            end

            -- cleanup / sink animation
            if isWaterOrTerrain or isTerrain then
                task.delay(1, function()
                    slab:SetAttribute("OGCframe", nil)
                    slab.Anchored = true
                    slab.AssemblyLinearVelocity  = Vector3.new()
                    slab.AssemblyAngularVelocity = Vector3.new()
                    slab.Velocity = Vector3.new()
                    slab.CFrame   = CFrame.new(1e8, 1e8, 1e8)
                    table.insert(partPool, slab)
                end)
            else
                local keepTime = addFlags.keep
                if not keepTime then
                    keepTime = rng:NextNumber(5, 7)
                end
                local sinkTween = v363.customtween or TweenInfo.new(2, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
                if v363.dispersefast then keepTime = v363.dispersefast end

                delay(keepTime, function()
                    if addFlags.keep then
                        TweenService:Create(slab, TweenInfo.new(2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                            CFrame = preTiltCF, Size = slab.Size
                        }):Play()
                        wait(2)
                    end
                    TweenService:Create(slab, sinkTween, {
                        CFrame = slab.CFrame * CFrame.new(0, -7, 0),
                        Size   = slab.Size / 1.5
                    }):Play()
                    wait(2)
                    slab:SetAttribute("OGCframe", nil)
                    slab.Anchored = true
                    slab.AssemblyLinearVelocity  = Vector3.new()
                    slab.AssemblyAngularVelocity = Vector3.new()
                    slab.Velocity = Vector3.new()
                    slab.CFrame   = CFrame.new(1e8, 1e8, 1e8)
                    table.insert(partPool, slab)
                end)
            end
        end
    end

    return ringSlabs
end

