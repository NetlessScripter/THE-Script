-- Make sure workspace.Thrown exists (required by the recycler/pool)
if not workspace:FindFirstChild("Thrown") then
    local f = Instance.new("Folder")
    f.Name   = "Thrown"
    f.Parent = workspace
end
if not workspace:FindFirstChild("Live") then
    local f = Instance.new("Folder")
    f.Name   = "Live"
    f.Parent = workspace
end

local player    = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local rootPart  = character:WaitForChild("HumanoidRootPart")

-- ── Example 1: Basic crater under the player ─────────────────
-- Raycasts straight down from the root part to find the ground,
-- then spawns a crater at that point.
local function spawnCraterUnderPlayer()
    local origin = rootPart.Position
    local ground, hitPos, _, normal = castRay({
        orig = origin,
        dir  = Vector3.new(0, -20, 0),
    })

    if not ground then
        -- Fallback: use position directly on Y=0 plane
        ground  = workspace.Terrain
        hitPos  = Vector3.new(origin.X, 0, origin.Z)
        normal  = Vector3.new(0, 1, 0)
    end

    GroundCrater({
        cframe   = CFrame.new(hitPos),
        normal   = normal or Vector3.new(0, 1, 0),
        ground   = ground,
        sizemult = 1,
        amount   = 16,
        Seed     = math.random(0, 9999),
        add      = { sounds = true },
    })
end

spawnCraterUnderPlayer()


