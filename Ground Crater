end)


-- ── Example 3: Quick-disperse crater (e.g. projectile impact) ──
task.delay(4, function()
    local origin = rootPart.Position + rootPart.CFrame.LookVector * 10
    local ground, hitPos, _, normal = castRay({
        orig = origin + Vector3.new(0, 5, 0),
        dir  = Vector3.new(0, -15, 0),
    })
    ground  = ground  or workspace.Terrain
    hitPos  = hitPos  or Vector3.new(origin.X, 0, origin.Z)
    normal  = normal  or Vector3.new(0, 1, 0)

    GroundCrater({
        cframe       = CFrame.new(hitPos),
        normal       = normal,
        ground       = ground,
        sizemult     = 0.75,
        amount       = 12,
        dispersefast = 1.5,   -- slabs sink after 1.5 s
        nodebris     = false,
        Seed         = os.clock(),
        add          = { sounds = true },
    })
end)
