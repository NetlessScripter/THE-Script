--[[
    GroundCrater_Standalone.lua
    Extracted from Stoic_Bomb__Port_.txt (TSB deobfuscated source)

    Exposes a public API via getgenv().GroundCrater so any script can use it.

    ── SETUP (run once, e.g. in your loader) ────────────────────────────────
    loadstring(game:HttpGet("...your raw URL here..."))()

    ── USAGE (from any script, after setup) ─────────────────────────────────

    -- 1. Simple: raycast down and fire the crater
    local GC = getgenv().GroundCrater
    local hit, hitPos, _, hitNormal = GC.ray({
        orig = Vector3.new(0, 10, 0),
        dir  = Vector3.new(0, -50, 0),
    })
    if hit then
        GC.fire({
            cframe   = CFrame.new(hitPos),
            ground   = hit,
            normal   = hitNormal,
            sizemult = 1,
            amount   = 16,
            add      = { sounds = true },
        })
    end

    -- 2. Fire directly (if you already have ground / normal)
    getgenv().GroundCrater.fire({
        cframe   = myCFrame,
        ground   = myGroundPart,
        normal   = myNormal,
        sizemult = 2,
        amount   = 24,
        add      = { sounds = true, less = false },
    })

    ── API REFERENCE ─────────────────────────────────────────────────────────
    getgenv().GroundCrater.fire(params)   — spawn the crater VFX
    getgenv().GroundCrater.ray(opts)      — raycast helper (returns inst, pos, mat, normal)
    getgenv().GroundCrater.version        — "1.0.0"

    params table (all fields optional except cframe, ground, normal):
      .cframe       CFrame      impact origin
      .ground       BasePart    surface that was hit
      .normal       Vector3     surface normal
      .sizemult     number      overall scale multiplier  (default 1)
      .amount       number      ring slab count           (default 16)
      .Seed         number      RNG seed for determinism
      .add          table       flags: .sounds, .less, .keep
      .nodebris     bool        skip flying debris chunks
      .notiles      bool        skip stadium tile break
      .nosound      bool        skip crater impact SFX
      .dispersefast number      auto-hide slabs after N seconds
      .customtween  TweenInfo
      .new          {minR,maxR} custom ring radius range
      .Double       number      spawn a second offset ring
      .angle / .anglecfr        optional angle-gate for slab visibility
      .dontcollide  Player      set CollisionGroup to nocol for LocalPlayer
]]

